{
  "name": "@qubit-ltd/clone",
  "version": "1.13.6",
  "description": "A JavaScript library provides a deep clone function",
  "author": "Haixing Hu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qubit-ltd/js-clone.git"
  },
  "bugs": {
    "url": "https://github.com/qubit-ltd/js-clone/issues"
  },
  "homepage": "https://github.com/qubit-ltd/js-clone",
  "main": "dist/clone.min.cjs",
  "module": "dist/clone.min.mjs",
  "exports": {
    ".": {
      "require": "./dist/clone.min.cjs",
      "import": "./dist/clone.min.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "doc/**/*",
    "LICENSE",
    "README.md",
    "README.zh_CN.md"
  ],
  "scripts": {
    "clean": "rm -rvf dist doc",
    "build": "cross-env NODE_ENV=production rollup -c rollup.config.mjs",
    "build:dev": "cross-env NODE_ENV=development rollup -c rollup.config.mjs",
    "build:all": "npm run clean && npm run doc && npm run build:dev && npm run build",
    "test": "jest",
    "lint": "eslint ./src ./test",
    "doc": "jsdoc -c jsdoc.json",
    "es5": "check-es-version --es-version=5 --show-error=true --target-dir=dist",
    "deploy": "npm run lint && npm run test && npm run build:all && npm publish --registry='https://registry.npmjs.org/' --access public"
  },
  "peerDependencies": {
    "@babel/runtime": "^7.28.5",
    "@qubit-ltd/naming-style": "^1.3.12",
    "@qubit-ltd/typeinfo": "^3.3.9"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.5",
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/runtime": "^7.28.5",
    "@jest/core": "^30.1.3",
    "@qubit-ltd/eslint-config": "^2.0.1",
    "@qubit-ltd/jsdoc-theme": "^1.5.2",
    "@qubit-ltd/naming-style": "^1.3.12",
    "@qubit-ltd/rollup-builder": "^1.8.14",
    "@qubit-ltd/type-detect": "^2.2.8",
    "@qubit-ltd/typeinfo": "^3.3.9",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@vue/compiler-dom": "^3.5.21",
    "@vue/server-renderer": "^3.5.21",
    "@vue/test-utils": "^2.4.6",
    "babel-jest": "^29.7.0",
    "check-es-version": "^1.5.1",
    "core-js": "^3.45.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-jsdom-global": "^4.0.0",
    "jest-extended": "^6.0.0",
    "jsdoc": "^4.0.4",
    "jsdom": "^26.1.0",
    "rollup": "^4.53.3",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.2",
    "vue": "^3.5.21"
  },
  "packageManager": "yarn@4.5.0"
}
